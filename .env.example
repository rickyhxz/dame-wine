# Copy to .env and fill in values

# Turso (get from: turso db show dame-wine --url  and  turso db tokens create dame-wine)
TURSO_DATABASE_URL="libsql://dame-wine-<your-turso-username>.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# Random secret for JWT session cookies — generate with: openssl rand -base64 32
JWT_SECRET="change-this-to-a-long-random-string"
